APP_NAME=PokeVote
APP_ENV=development
APP_DEBUG=1
APP_TIMEZONE=UTC
APP_SECRET=local-dev-secret-change-me
ADMIN_KEY=dev-admin-key

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pokevote
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

ELO_BASE=1500
ELO_K_FACTOR=32
OVERALL_CATEGORY_SLUG=overall

VOTE_COOLDOWN_SECONDS=2
PAIR_COOLDOWN_SECONDS=900
IP_HOURLY_VOTE_LIMIT=120
MAX_PAIR_VOTES_PER_IP_PER_DAY=4
LEADERBOARD_LIMIT=200
